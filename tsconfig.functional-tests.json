{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "outDir": ".test-dist",
    "rootDir": ".",
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": false,
    "isolatedModules": false,
    "lib": ["ES2022", "DOM"]
  },
  "include": [
    "src/lib/**/*.ts",
    "tests/**/*.ts",
    "tests/**/*.d.ts"
  ]
}
